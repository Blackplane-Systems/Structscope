{
  "name": "struct-scope",
  "displayName": "Struct Scope",
  "publisher": "BlackplaneSystems",
  "version": "3.1.2",
  "description": "Visualize C, C++, and Rust struct memory layout, padding, cache-line splits, and reorder suggestions.",
  "author": {
    "name": "Brahadeesh V Ra",
    "email": "144269250+CodeforGood1@users.noreply.github.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Blackplane-Systems/Structscope.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:rust",
    "onView:structscope.dashboard",
    "onCommand:structscope.analyzeStruct",
    "onCommand:structscope.openPanel",
    "onCommand:structscope.runCliInTerminal",
    "onCommand:structscope.copyAnalysisJson",
    "onCommand:structscope.showOutput"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc --noEmit",
    "build": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js",
    "package": "vsce package",
    "cli": "python python/cli.py"
  },
  "contributes": {
    "commands": [
      {
        "command": "structscope.analyzeStruct",
        "title": "StructScope: Analyze Struct",
        "icon": "$(play)"
      },
      {
        "command": "structscope.openPanel",
        "title": "StructScope: Open Dashboard",
        "icon": "$(layout-panel)"
      },
      {
        "command": "structscope.runCliInTerminal",
        "title": "StructScope: Run CLI in Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "structscope.copyAnalysisJson",
        "title": "StructScope: Copy Last Analysis JSON",
        "icon": "$(copy)"
      },
      {
        "command": "structscope.showOutput",
        "title": "StructScope: Show Output Log",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "structscope.analyzeStruct",
          "when": "resourceLangId == c || resourceLangId == cpp || resourceLangId == rust",
          "group": "navigation@1"
        },
        {
          "command": "structscope.openPanel",
          "when": "resourceLangId == c || resourceLangId == cpp || resourceLangId == rust",
          "group": "navigation@2"
        },
        {
          "command": "structscope.runCliInTerminal",
          "when": "resourceLangId == c || resourceLangId == cpp || resourceLangId == rust",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "command": "structscope.analyzeStruct",
          "when": "resourceLangId == c || resourceLangId == cpp || resourceLangId == rust",
          "group": "navigation"
        },
        {
          "command": "structscope.runCliInTerminal",
          "when": "resourceLangId == c || resourceLangId == cpp || resourceLangId == rust",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "structscope.analyzeStruct",
          "when": "view == structscope.dashboard",
          "group": "navigation"
        },
        {
          "command": "structscope.openPanel",
          "when": "view == structscope.dashboard",
          "group": "navigation"
        },
        {
          "command": "structscope.runCliInTerminal",
          "when": "view == structscope.dashboard",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "structscope",
          "title": "StructScope",
          "icon": "resources/structscope.svg"
        }
      ]
    },
    "views": {
      "structscope": [
        {
          "id": "structscope.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "keybindings": [
      {
        "command": "structscope.analyzeStruct",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "StructScope",
      "properties": {
        "structscope.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional Python executable path used to run StructScope's analysis server."
        },
        "structscope.defaultPlatform": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "x86_64",
            "x86_64_windows",
            "arm64",
            "arm64_windows",
            "arm32",
            "avr",
            "riscv32",
            "riscv64"
          ],
          "description": "Default ABI platform. Use auto to detect the host Python ABI; select an explicit platform for cross-compilers."
        },
        "structscope.cacheLine": {
          "type": "number",
          "default": 64,
          "enum": [
            32,
            64,
            128
          ],
          "description": "Default cache-line size in bytes."
        },
        "structscope.analyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically analyze supported C, C++, and Rust files on save."
        },
        "structscope.autoOpenPanel": {
          "type": "boolean",
          "default": true,
          "description": "Open the StructScope dashboard automatically when analysis runs on save."
        },
        "structscope.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the StructScope status bar command."
        },
        "structscope.allowIncompleteLayouts": {
          "type": "boolean",
          "default": false,
          "description": "Allow non-authoritative partial results for unresolved types or bit-fields. Exact analysis fails fast when disabled."
        },
        "structscope.requestTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 120000,
          "description": "Timeout in milliseconds for each Python backend request."
        },
        "structscope.autoInstallPythonDeps": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install StructScope Python parser dependencies with pip when they are missing."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.27.0",
    "typescript": "^5.4.0"
  }
}
